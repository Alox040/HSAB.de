# HSA Seniorenbetreuung — Environment Variables
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local or any file containing real secrets.

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=posdziech@t-online.de

# Verified sender address in Resend — must be from a domain you verified in Resend
# The onboarding@resend.dev address only works in sandbox/test mode
CONTACT_FROM_EMAIL=kontakt@seniorenbetreuung.de
